{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praise.local/gd-v7/gd-plan-suite.schema.json",
  "title": "GD Plan Suite",
  "description": "Schema for /gd master plan + step plan goal/SC blocks. Plan F v9: added work_items, step_clusters (with chosen/removal_proof/alternatives_rejected), step_plan_inventory, wave_matrix.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_kind",
    "gd_standard",
    "goal_source",
    "goal_chain",
    "review_alignment",
    "success_criteria",
    "non_goals",
    "boundaries",
    "work_items",
    "step_clusters"
  ],
  "properties": {
    "template_kind": {
      "type": "string",
      "enum": ["gd-master-plan", "gd-step-plan"]
    },
    "gd_standard": {
      "type": "string",
      "const": "Project GD/prompts/gd-review-standard.md"
    },
    "goal_source": {
      "type": "string",
      "const": "Project GD/docs/gd-v7-project-goal.md"
    },
    "goal_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["PROJECT_GOAL", "CHAIN_GOAL", "PHASE_GOAL"],
      "properties": {
        "PROJECT_GOAL": { "type": "string", "minLength": 10 },
        "CHAIN_GOAL": { "type": "string", "minLength": 10 },
        "PHASE_GOAL": { "type": "string", "minLength": 10 },
        "TASK_GOAL": { "type": "string", "minLength": 10 }
      }
    },
    "review_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["REVIEW_DOMAIN", "REVIEW_FOCUS"],
      "properties": {
        "REVIEW_DOMAIN": {
          "type": "string",
          "enum": ["ai_infra", "app_code", "docs_content", "other"]
        },
        "REVIEW_FOCUS": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 3,
          "maxItems": 5
        },
        "domain_specific_notes": { "type": "string" }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sc_id", "description", "verify"],
        "properties": {
          "sc_id": { "type": "string", "pattern": "^SC-[0-9]+$" },
          "description": { "type": "string", "minLength": 10 },
          "verify": {
            "description": "Anti-fill rule A: must contain command/path/assertion/test",
            "type": "object",
            "additionalProperties": false,
            "required": ["method", "expression"],
            "properties": {
              "method": { "type": "string", "enum": ["command", "path", "assertion", "test"] },
              "expression": { "type": "string", "minLength": 3 },
              "expect": { "type": "string" }
            }
          }
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modify", "do_not_modify"],
      "properties": {
        "modify": { "type": "array", "items": { "type": "string" } },
        "do_not_modify": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "task_packets": {
      "type": "array",
      "description": "List of task_packet file paths; each file conforms to gd-task-packet.schema.json",
      "items": { "type": "string" }
    },
    "work_items": {
      "description": "Plan F v9: machine-readable work items with evidence_anchor. Extracted from 'json gd-work-items' fenced block.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "sc_refs", "evidence_anchor"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 300
          },
          "sc_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SC-[0-9]+$" },
            "minItems": 1
          },
          "evidence_anchor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["file_line", "command_expect", "hash", "path_glob", "fixture", "doc_section"]
              },
              "ref": { "type": "string", "minLength": 1, "maxLength": 500 }
            }
          }
        }
      }
    },
    "step_clusters": {
      "description": "Plan F v9: step cluster decisions with chosen (≤100), removal_proof, alternatives_rejected (≥1). Extracted from 'json gd-step-clusters' fenced block.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cluster_id", "step_ids", "clustering_reason", "alternatives_rejected", "chosen", "removal_proof"],
        "properties": {
          "cluster_id": { "type": "string", "minLength": 1 },
          "step_ids": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "task_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "clustering_reason": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "description"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["dependency", "domain", "risk", "performance", "sequencing", "coupling", "resource", "error_propagation", "test_isolation", "data_flow", "state_sharing"]
              },
              "description": { "type": "string", "minLength": 10 }
            }
          },
          "alternatives_rejected": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["option", "reason"],
              "properties": {
                "option": { "type": "string", "minLength": 3 },
                "reason": { "type": "string", "minLength": 5, "maxLength": 200 }
              }
            }
          },
          "chosen": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100
          },
          "removal_proof": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500
          },
          "evidence_anchor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["file_line", "command_expect", "hash", "path_glob", "fixture", "doc_section"]
              },
              "ref": { "type": "string", "minLength": 1, "maxLength": 500 }
            }
          }
        }
      }
    },
    "step_plan_inventory": {
      "description": "Plan F v9: inventory of step plan files. Plan 3 v2: task_packet_mode is REQUIRED — declares whether the step plan ships zero (none_single_task) or two-or-more (multi_task) task packets, and the plan-semantic validator cross-checks this against the actual task_packets array.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "file", "status", "task_packet_mode"],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["draft", "reviewed", "approved", "executing", "done", "blocked"]
          },
          "task_packets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "task_packet_mode": {
            "description": "Plan 3 v2 (P3): step ships either no packets (single-step task) or two-plus packets (parallelizable). The validator rejects exactly-one-packet to force the planner to pick a side honestly.",
            "type": "string",
            "enum": ["none_single_task", "multi_task"]
          },
          "owned_paths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_paths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_context": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "kind", "must_exist"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "kind": { "type": "string", "enum": ["file", "directory", "report"] },
                "must_exist": { "type": "boolean" }
              }
            }
          },
          "sc_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^(?:[A-Z][A-Z0-9]*-)?SC-[0-9]+$" }
          },
          "verify": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sc_ref", "method", "cmd"],
              "properties": {
                "sc_ref": { "type": "string", "pattern": "^(?:[A-Z][A-Z0-9]*-)?SC-[0-9]+$" },
                "method": { "type": "string", "enum": ["command", "path", "assertion", "test"] },
                "cmd": { "type": "string", "minLength": 3 },
                "expect": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "governance": {
      "description": "Plan 3 v2: review-queue capacity governance. Declares the codex review-queue limit, whether the plan ships parent-close + release-evidence jobs, and (when over capacity) the explicit step→group mapping. The plan-semantic validator enforces step_count, queue capacity, group coverage, and bans boolean self-attestation.",
      "type": "object",
      "additionalProperties": false,
      "required": ["queue_limit", "review_strategy", "has_parent_close", "has_release_evidence"],
      "properties": {
        "queue_limit": {
          "description": "Plan H today is 10 (master + 7 subplans + parent_close + release_evidence). Locked here so the validator math is auditable.",
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "review_strategy": {
          "description": "full_per_step requires 1 review job per step; grouped_explicit collapses steps into named groups (each consumes 1 review job).",
          "type": "string",
          "enum": ["full_per_step", "grouped_explicit"]
        },
        "has_parent_close": {
          "type": "boolean"
        },
        "has_release_evidence": {
          "type": "boolean"
        },
        "grouping_strategy": {
          "description": "REQUIRED when review_strategy=grouped_explicit. MUST be omitted (or null) when review_strategy=full_per_step.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["groups"],
              "properties": {
                "groups": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name", "step_ids"],
                    "properties": {
                      "name": { "type": "string", "minLength": 1, "maxLength": 80 },
                      "step_ids": {
                        "type": "array",
                        "minItems": 1,
                        "items": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        "user_choice_recorded": {
          "description": "Optional human-readable note ONLY. The semantic validator never accepts this as evidence — detailed grouping_strategy must still satisfy capacity rules.",
          "type": "boolean"
        }
      }
    },
    "wave_matrix": {
      "description": "Plan F v9: wave assignment matrix. max_parallel ≤ 2 (Plan 6.5-C). Extracted from 'json gd-wave-matrix' fenced block.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wave_id", "tracks"],
        "properties": {
          "wave_id": { "type": "string", "minLength": 1 },
          "tracks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["track_id", "mode", "step_ids"],
              "properties": {
                "track_id": { "type": "string", "minLength": 1 },
                "mode": {
                  "type": "string",
                  "enum": ["plan", "execute", "review", "validate"]
                },
                "step_ids": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "max_parallel": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 2
                }
              }
            }
          },
          "blocked_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
