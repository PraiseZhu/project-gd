{
  "version": "1.0.0",
  "description": "SSOT secret scan regex patterns. Used by bin/gd-sync-codex-chain.sh and scripts/gd-codex-chain-release-status.sh. Do not duplicate — always source from this file.",
  "patterns": [
    {
      "id": "anthropic_sk",
      "regex": "sk-ant-[A-Za-z0-9_-]{20,}",
      "description": "Anthropic API key",
      "severity": "critical"
    },
    {
      "id": "openai_sk",
      "regex": "sk-[A-Za-z0-9_-]{20,}",
      "description": "OpenAI / generic sk-prefixed API key",
      "severity": "critical"
    },
    {
      "id": "github_token",
      "regex": "gh[pousr]_[A-Za-z0-9_]{36,}",
      "description": "GitHub personal/oauth/app/refresh token",
      "severity": "critical"
    },
    {
      "id": "aws_access_key",
      "regex": "AKIA[0-9A-Z]{16}",
      "description": "AWS access key ID",
      "severity": "critical"
    },
    {
      "id": "aws_secret_key",
      "regex": "AWS_SECRET[A-Za-z0-9_]*[=:][[:space:]]*[A-Za-z0-9+/]{20,}",
      "description": "AWS secret access key (context-anchored, ERE-compatible, avoids SHA-256 false positives)",
      "severity": "high"
    },
    {
      "id": "jwt",
      "regex": "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
      "description": "JSON Web Token",
      "severity": "high"
    },
    {
      "id": "private_key_header",
      "regex": "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----",
      "description": "PEM private key header",
      "severity": "critical"
    },
    {
      "id": "generic_bearer",
      "regex": "Bearer [A-Za-z0-9_\\-\\.]{20,}",
      "description": "Generic Bearer token in Authorization header",
      "severity": "medium"
    }
  ],
  "excluded_filenames_note": "Documentation only — these filenames are excluded by the SYNC SCRIPT allowlist (gd-sync-codex-chain.sh), NOT by grep at scan time. The grep scan does not implement --exclude for these; their absence from the mirror is enforced upstream by the sync allowlist.",
  "excluded_filenames": [
    "auth.json",
    "*.token.json",
    "credentials.json",
    "*.key",
    "*.pem",
    "*.p8",
    "*.pfx"
  ],
  "redact_placeholder": "<REDACTED>"
}
