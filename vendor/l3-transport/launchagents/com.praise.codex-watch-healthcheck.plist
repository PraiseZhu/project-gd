<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Placeholders (__HOME__ / __HANDOFF_BIN__ / __HANDOFF_STATE__ / __CLAUDE_PLUGIN_DATA__)
     are rendered by install-transport.sh against state-paths.sh-resolved values at deploy time.
     This bundle file MUST NOT contain any developer-machine absolute path.
     TAPTAP_API_KEY stays REDACTED; injected by installer via launchctl setenv.
     __CLAUDE_PLUGIN_DATA__ is required so healthcheck resolves the SAME gd-handoff state root
     the daemon writes to; without it healthcheck reads the wrong (empty) heartbeat and
     kickstart-kills a healthy daemon every StartInterval. -->
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>__HOME__</string>
		<key>PATH</key>
		<string>__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>TAPTAP_API_KEY</key>
		<string>&lt;REDACTED-set-via-install-or-launchctl-setenv&gt;</string>
		<key>CLAUDE_PLUGIN_DATA</key>
		<string>__CLAUDE_PLUGIN_DATA__</string>
	</dict>
	<key>Label</key>
	<string>com.praise.codex-watch-healthcheck</string>
	<key>ProgramArguments</key>
	<array>
		<string>__HANDOFF_BIN__/codex-watch-healthcheck</string>
	</array>
	<key>StandardErrorPath</key>
	<string>__HANDOFF_STATE__/codex-watch-launchd.log</string>
	<key>StandardOutPath</key>
	<string>__HANDOFF_STATE__/codex-watch-launchd.log</string>
	<key>StartInterval</key>
	<integer>60</integer>
</dict>
</plist>
