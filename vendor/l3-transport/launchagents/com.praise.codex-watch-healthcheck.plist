<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/praise</string>
		<key>PATH</key>
		<string>/Users/praise/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>TAPTAP_API_KEY</key>
		<string>&lt;REDACTED-set-via-install-or-launchctl-setenv&gt;</string>
	</dict>
	<key>Label</key>
	<string>com.praise.codex-watch-healthcheck</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Users/praise/.claude/handoff/bin/codex-watch-healthcheck</string>
	</array>
	<key>StandardErrorPath</key>
	<string>/Users/praise/.claude/handoff/state/codex-watch-launchd.log</string>
	<key>StandardOutPath</key>
	<string>/Users/praise/.claude/handoff/state/codex-watch-launchd.log</string>
	<key>StartInterval</key>
	<integer>60</integer>
</dict>
</plist>
