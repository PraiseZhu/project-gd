#!/usr/bin/env bash
# Pure read-only watcher liveness check.
# Exit codes: 0=RUNNING, 2=DEGRADED_HEARTBEAT_ONLY, 1=STOPPED
# Does NOT modify any state files (no rm, no write).
set -euo pipefail
source "$(dirname "$0")/../lib/state-paths.sh"
source "$(dirname "$0")/../lib/watch-state.sh"

state=$(watch_state)
rc=$?
echo "$state"
exit $rc
