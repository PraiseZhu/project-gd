#!/usr/bin/env bash
# Send a capsule and wait for the result from codex-watch.
# Mode-aware completion: review‚ÜíVERDICT, discuss‚ÜíRECOMMENDATION (SC-02)
# Exit codes:
#   0 ‚Äî complete, result contains valid completion marker (mode-dependent)
#   1 ‚Äî usage error
#   2 ‚Äî watcher stopped (WATCH_UNAVAILABLE)
#   3 ‚Äî timeout
#   4 ‚Äî failed (status=failed or no valid completion marker)
#   5 ‚Äî batch cancelled before this job ran (Plan 9 Phase B)
#   6 ‚Äî batch cancelled while this job was running; result preserved as
#       <job>.stale_completed.json but NOT trusted (Plan 9 Phase B)
set -euo pipefail
source "$(dirname "$0")/../lib/state-paths.sh"
source "$(dirname "$0")/../lib/watch-state.sh"

TIMEOUT="${CODEX_SEND_WAIT_TIMEOUT:-540}"
POLL_INTERVAL=2

usage() {
  echo "Usage: codex-send-wait --cwd <dir> --mode <mode> --payload-file <file> [--timeout <sec>] [--exec-timeout <sec>]"
  exit 1
}

cwd="" mode="" payload_file="" exec_timeout=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --cwd)          cwd="$2"; shift 2 ;;
    --mode)         mode="$2"; shift 2 ;;
    --payload-file) payload_file="$2"; shift 2 ;;
    --timeout)      TIMEOUT="$2"; shift 2 ;;
    --exec-timeout) exec_timeout="$2"; shift 2 ;;
    *) usage ;;
  esac
done

[[ -z "$cwd" || -z "$mode" || -z "$payload_file" ]] && usage
[[ ! -f "$payload_file" ]] && { echo "Error: payload file not found: $payload_file" >&2; exit 1; }
if [[ -n "$exec_timeout" ]]; then
  case "$exec_timeout" in
    *[!0-9]*|0) echo "Error: --exec-timeout must be a positive integer" >&2; exit 1 ;;
  esac
fi

# Check watcher state via shared watch_state()
# NOTE: must NOT let `set -e` abort on this line. watch_state() returns non-zero
# for DEGRADED (2) and STOPPED (1). A bare `watcher_status=$(watch_state)`
# assignment trips `set -e` and exits the script with that code BEFORE the
# graceful `case` below runs ‚Äî turning a clear "WATCH_UNAVAILABLE exit 2 +
# message" (STOPPED) or a "proceed anyway" (DEGRADED) into a silent exit 1 with
# empty output (observed: empty 1-byte error log when the daemon was mid-restart).
# `|| watcher_rc=$?` captures the real code and keeps set -e satisfied.
watcher_rc=0
watcher_status=$(watch_state) || watcher_rc=$?

case $watcher_rc in
  0)
    # RUNNING ‚Äî proceed normally
    ;;
  2)
    # DEGRADED_HEARTBEAT_ONLY ‚Äî warn but continue; heartbeat fresh so watcher likely still alive
    echo "[WARN] codex-watch is DEGRADED (${watcher_status}); proceeding anyway" >&2
    ;;
  *)
    # STOPPED ‚Äî cannot submit
    echo "WATCH_UNAVAILABLE: ${watcher_status}" >&2
    exit 2
    ;;
esac

# Submit via codex-send. --exec-timeout is persisted in job metadata and read
# by codex-watch; it cannot be expressed through this client process env because
# the daemon is already running under launchd.
send_args=(--cwd "$cwd" --mode "$mode" --payload-file "$payload_file")
if [[ -n "$exec_timeout" ]]; then
  send_args+=(--exec-timeout "$exec_timeout")
fi
job_id=$("$HANDOFF_BIN/codex-send" "${send_args[@]}")
status_file="${HANDOFF_ACTIVE}/${job_id}.status"
result_file="${HANDOFF_ACTIVE}/${job_id}.result"
stderr_file="${HANDOFF_ACTIVE}/${job_id}.stderr"

# Poll for terminal status (done or failed)
elapsed=0
while [[ $elapsed -lt $TIMEOUT ]]; do
  if [[ -f "$status_file" ]]; then
    current_status=$(cat "$status_file")
    case "$current_status" in
      done)
        if [[ -f "$result_file" ]]; then
          # Mode-aware completion check (SC-02): review‚ÜíVERDICT, discuss‚ÜíRECOMMENDATION
          if [[ "$mode" == "discuss" ]]; then
            if grep -qE '^RECOMMENDATION:' "$result_file"; then
              cat "$result_file"
              exit 0
            else
              echo "Error: discuss completed but result contains no RECOMMENDATION" >&2
              cat "$result_file" >&2
              exit 4
            fi
          elif grep -qE '^VERDICT: (APPROVED|REQUIRES_CHANGES)' "$result_file"; then
            cat "$result_file"
            exit 0
          else
            echo "Error: review completed but result contains no valid VERDICT" >&2
            cat "$result_file" >&2
            exit 4
          fi
        else
          echo "Error: status=done but no result file for job $job_id" >&2
          exit 4
        fi
        ;;
      failed)
        echo "Error: review failed for job $job_id" >&2
        if [[ -f "$result_file" ]]; then
          cat "$result_file" >&2
        fi
        if [[ -f "$stderr_file" ]]; then
          echo "--- stderr (first 10 lines) ---" >&2
          head -10 "$stderr_file" >&2
        fi
        exit 4
        ;;
      cancelled)
        # Plan 9 Phase B: batch was cancelled before this job ran.
        echo "CANCELLED: job $job_id was cancelled before execution" >&2
        exit 5
        ;;
      stale_completed)
        # Plan 9 Phase B: batch was cancelled while job was running.
        # Raw evidence preserved but result is NOT trusted.
        echo "STALE_COMPLETED: job $job_id finished after batch cancel; result not trusted" >&2
        local stale_path="${HANDOFF_ACTIVE}/${job_id}.stale_completed.json"
        if [[ -f "$stale_path" ]]; then
          echo "Raw evidence preserved at: $stale_path" >&2
        fi
        exit 6
        ;;
      queued|running)
        # Still in progress, keep polling
        ;;
      *)
        echo "Error: unknown status '$current_status' for job $job_id" >&2
        exit 4
        ;;
    esac
  fi
  sleep "$POLL_INTERVAL"
  elapsed=$((elapsed + POLL_INTERVAL))
done

echo "TIMEOUT: no terminal status after ${TIMEOUT}s for job ${job_id}" >&2
exit 3
