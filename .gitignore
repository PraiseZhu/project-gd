# === Sensitive ===
.env
.env.*
!.env.example
*.key
*.pem
*.token.json
.auth.json
credentials/
secrets/

# === macOS / iCloud ===
.DS_Store
._*
*.icloud
*.swp
*.swo

# === ECC session data (managed externally) ===
history/checkpoints/
history/daily/
.claude/

# === Logs ===
*.log
logs/

# === IDE ===
.idea/
.vscode/

# === Planning workflow (pwf skill — local only) ===
.planning/

# === Tip: 大数据目录建议加 .nosync 后缀，iCloud 不同步 ===
# 例：raw-data.nosync/  models.nosync/

# === codex-chain 镜像兜底排除（belt-and-suspenders）===
mirrors/codex-chain/**/auth.json
mirrors/codex-chain/**/*.sqlite*
mirrors/codex-chain/**/sessions/
mirrors/codex-chain/**/cache/
mirrors/codex-chain/**/.tmp/
mirrors/codex-chain/**/tmp/
mirrors/codex-chain/**/shell_snapshots/
mirrors/codex-chain/**/archived_sessions/
mirrors/codex-chain/**/log/
mirrors/codex-chain/**/.run-jitter-salt
mirrors/codex-chain/**/__pycache__/
mirrors/codex-chain/**/computer-use/
mirrors/codex-chain/**/ambient-suggestions/

# === Python bytecode (global) ===
__pycache__/
*.pyc
*.pyo
*.pyd

# === results/ + reports/ run artifacts (local-only by default) ===
# Execution runs, route reports, smoke/dogfood dumps, capsule outputs, and
# deployment backups under results/ and reports/ are local-only run artifacts.
# NOTE: .gitignore does NOT untrack files already committed under these dirs;
# this only stops NEW untracked artifacts from entering the index.
results/*
reports/*
# Plan-dir e2e/run artifacts (regenerable; excluded per SC-18/SC-24 intent)
plans/gd/*/results/
# Curated release evidence stays committable (run-manifest.json + approved artifacts).
!results/release-evidence/

# === scratch work dirs (underscore-prefixed, local-only) ===
_regwork/

# pytest sandbox fallback temp dir (conftest _ensure_writable_tmpdir)
.pytest-tmp/
