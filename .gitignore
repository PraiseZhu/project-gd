# === codex-chain 镜像兜底排除（belt-and-suspenders）===
mirrors/codex-chain/**/auth.json
mirrors/codex-chain/**/*.sqlite*
mirrors/codex-chain/**/sessions/
mirrors/codex-chain/**/cache/
mirrors/codex-chain/**/.tmp/
mirrors/codex-chain/**/tmp/
mirrors/codex-chain/**/shell_snapshots/
mirrors/codex-chain/**/archived_sessions/
mirrors/codex-chain/**/log/
mirrors/codex-chain/**/.run-jitter-salt
mirrors/codex-chain/**/__pycache__/
mirrors/codex-chain/**/computer-use/
mirrors/codex-chain/**/ambient-suggestions/

# === Python bytecode (global) ===
__pycache__/
*.pyc
*.pyo
*.pyd

# === review2 / release-evidence run artifacts ===
# raw capsule runs and review route split artifacts are local-only by default
results/review-route-split/*/raw-*
results/review-route-split/*/codex-output-*
# run-manifest.json and curated evidence under release-evidence/ should be committed explicitly
# results/release-evidence/ is NOT gitignored — commit run-manifest.json + approved artifacts

# === install-gd-command.sh deployment backups (pre-overwrite snapshots) ===
# install-gd-command.sh writes the previous live gd.md to this dir before atomic overwrite.
# These are pure deployment artifacts — recoverable from prior installs, not project source.
reports/_selftest_runtime_evidence/installed-backup/
