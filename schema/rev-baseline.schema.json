{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RevBaseline",
  "description": "Minimal rev baseline for Goal-Driven Anti-Fill Lab. Only goal chain + SC fields allowed.",
  "type": "object",
  "required": ["goal_chain", "success_criteria", "plan_hash", "non_goals", "accepted_decisions"],
  "additionalProperties": false,
  "properties": {
    "goal_chain": {
      "type": "object",
      "required": ["project", "chain", "phase", "task"],
      "additionalProperties": false,
      "properties": {
        "project": {"type": "string", "minLength": 1},
        "chain":   {"type": "string", "minLength": 1},
        "phase":   {"type": "string", "minLength": 1},
        "task":    {"type": "string", "minLength": 1}
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "verify"],
        "additionalProperties": false,
        "properties": {
          "id":     {"type": "string", "pattern": "^SC-[0-9]+$"},
          "text":   {"type": "string", "minLength": 1},
          "verify": {"type": "string", "minLength": 1}
        }
      }
    },
    "plan_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "non_goals": {
      "type": "array",
      "items": {"type": "string"}
    },
    "accepted_decisions": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
