{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praise.local/gd-v7/gd-review-result-v2.schema.json",
  "title": "GD Review Result v2",
  "description": "Canonical schema for GD review v2 mapped results. Structure MUST match gd-codex-bridge-review.py _validate_v2 (bridge enforces a fail-closed subset; this file is the full contract). Enums sourced from gd_review_contract.py SSOT. 13 allOf: 4 base-enum + 1 cross-rule + 4 review_kind→target_role + 4 review_kind→template_kind.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "template_kind",
    "review_kind",
    "review_target_kind",
    "target_role",
    "reviewer",
    "review_target",
    "review_run_status",
    "gd_review_decision",
    "source_of_truth_decision",
    "scope_checked",
    "findings",
    "merge_notes",
    "residual_risk",
    "timestamp"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0" },
    "template_kind": {
      "type": "string",
      "enum": ["gd-plan-review", "gd-execution-outcome-review", "gd-code-diff-review", "gd-combined-review"]
    },
    "review_kind": {
      "type": "string",
      "enum": ["plan", "execution_outcome", "code_diff", "combined"]
    },
    "review_target_kind": {
      "type": "string",
      "enum": ["plan_only", "execution_only_no_code", "code_only", "execution_plus_code", "no_artifact", "ambiguous_mixed_artifacts"]
    },
    "target_role": {
      "type": "string",
      "enum": ["plan_artifact", "execution_artifact", "code_diff", "combined_bundle"]
    },
    "reviewer": {
      "type": "string",
      "pattern": "^(claude_main|claude_subagent_[a-z0-9_]+|codex)$"
    },
    "review_target": { "type": "string", "minLength": 1 },
    "review_run_status": {
      "type": "string",
      "enum": ["completed", "completed_with_constraint", "degraded", "failed_to_run"]
    },
    "gd_review_decision": {
      "type": "string",
      "enum": ["APPROVED", "REQUIRES_CHANGES", "FAILED"]
    },
    "source_of_truth_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["location", "value"],
      "properties": {
        "location": { "type": "string", "enum": ["top_level_machine_header", "fenced_json_block"] },
        "value": { "type": "string", "enum": ["APPROVED", "REQUIRES_CHANGES", "FAILED"] }
      }
    },
    "scope_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["area", "result", "evidence"],
        "properties": {
          "area": { "type": "string", "minLength": 1 },
          "result": { "type": "string", "enum": ["pass", "fail", "n_a"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "sc_refs", "evidence", "impact", "required_fix", "verify"],
        "properties": {
          "severity": { "type": "string", "enum": ["P1", "P2"] },
          "title": { "type": "string", "minLength": 1 },
          "sc_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "evidence": { "type": "string" },
          "impact": { "type": "string" },
          "required_fix": { "type": "string" },
          "verify": { "type": "string" }
        }
      }
    },
    "merge_notes": {
      "type": "object",
      "properties": {
        "conflict_with_other_reviewer": { "type": "boolean" },
        "arbitration_reason": { "type": "string" },
        "degraded_reason": { "type": "string" }
      }
    },
    "residual_risk": { "type": "string" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}"
    },
    "compatibility_mode": { "type": "string" },
    "cross_validation_findings": { "type": "array", "items": { "type": "object" } },
    "run_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cmd": {"type": "string"},
          "exit": {"type": "integer"},
          "passed": {"type": "integer"},
          "failed": {"type": "integer"},
          "skipped": {"type": "integer"},
          "skip_reason": {"type": "string"},
          "interpreter_version": {"type": "string"}
        }
      }
    }
  },
  "allOf": [
    {
      "$comment": "base-1: schema_version 2.0",
      "properties": { "schema_version": { "const": "2.0" } }
    },
    {
      "$comment": "base-2: review_kind enum",
      "properties": { "review_kind": { "enum": ["plan", "execution_outcome", "code_diff", "combined"] } }
    },
    {
      "$comment": "base-3: review_target_kind enum",
      "properties": { "review_target_kind": { "enum": ["plan_only", "execution_only_no_code", "code_only", "execution_plus_code", "no_artifact", "ambiguous_mixed_artifacts"] } }
    },
    {
      "$comment": "base-4: target_role enum",
      "properties": { "target_role": { "enum": ["plan_artifact", "execution_artifact", "code_diff", "combined_bundle"] } }
    },
    {
      "$comment": "cross-rule: cross_validation_findings only allowed for combined",
      "if": { "properties": { "review_kind": { "not": { "const": "combined" } } } },
      "then": { "not": { "required": ["cross_validation_findings"] } }
    },
    {
      "$comment": "review_kind=plan → target_role=plan_artifact",
      "if": { "properties": { "review_kind": { "const": "plan" } } },
      "then": { "properties": { "target_role": { "const": "plan_artifact" } } }
    },
    {
      "$comment": "review_kind=execution_outcome → target_role=execution_artifact",
      "if": { "properties": { "review_kind": { "const": "execution_outcome" } } },
      "then": { "properties": { "target_role": { "const": "execution_artifact" } } }
    },
    {
      "$comment": "review_kind=code_diff → target_role=code_diff",
      "if": { "properties": { "review_kind": { "const": "code_diff" } } },
      "then": { "properties": { "target_role": { "const": "code_diff" } } }
    },
    {
      "$comment": "review_kind=combined → target_role=combined_bundle",
      "if": { "properties": { "review_kind": { "const": "combined" } } },
      "then": { "properties": { "target_role": { "const": "combined_bundle" } } }
    },
    {
      "$comment": "review_kind=plan → template_kind=gd-plan-review",
      "if": { "properties": { "review_kind": { "const": "plan" } } },
      "then": { "properties": { "template_kind": { "const": "gd-plan-review" } } }
    },
    {
      "$comment": "review_kind=execution_outcome → template_kind=gd-execution-outcome-review",
      "if": { "properties": { "review_kind": { "const": "execution_outcome" } } },
      "then": { "properties": { "template_kind": { "const": "gd-execution-outcome-review" } } }
    },
    {
      "$comment": "review_kind=code_diff → template_kind=gd-code-diff-review",
      "if": { "properties": { "review_kind": { "const": "code_diff" } } },
      "then": { "properties": { "template_kind": { "const": "gd-code-diff-review" } } }
    },
    {
      "$comment": "review_kind=combined → template_kind=gd-combined-review",
      "if": { "properties": { "review_kind": { "const": "combined" } } },
      "then": { "properties": { "template_kind": { "const": "gd-combined-review" } } }
    }
  ]
}
