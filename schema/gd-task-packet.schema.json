{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praise.local/gd-v7/gd-task-packet.schema.json",
  "title": "GD Task Packet",
  "description": "Self-contained packet for sub-agent execution; must not depend on conversation context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_kind",
    "gd_standard",
    "goal_source",
    "task_id",
    "agent_role",
    "parent_step",
    "parent_plan",
    "goal_chain",
    "blocked_by",
    "can_parallel_with",
    "required_context",
    "owned_paths",
    "forbidden_paths",
    "success_criteria",
    "deliverables",
    "verify",
    "handoff_output"
  ],
  "properties": {
    "template_kind": { "const": "gd-task-packet" },
    "gd_standard": { "const": "Project GD/prompts/gd-review-standard.md" },
    "goal_source": { "const": "Project GD/docs/gd-v7-project-goal.md" },
    "task_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "agent_role": { "type": "string", "minLength": 3 },
    "parent_step": { "type": "string", "minLength": 1 },
    "parent_plan": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "goal_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["PROJECT_GOAL", "CHAIN_GOAL", "PHASE_GOAL", "TASK_GOAL"],
      "properties": {
        "PROJECT_GOAL": { "type": "string", "minLength": 10 },
        "CHAIN_GOAL": { "type": "string", "minLength": 10 },
        "PHASE_GOAL": { "type": "string", "minLength": 10 },
        "TASK_GOAL": { "type": "string", "minLength": 10 }
      }
    },
    "blocked_by": { "type": "array", "items": { "type": "string" } },
    "can_parallel_with": { "type": "array", "items": { "type": "string" } },
    "required_context": {
      "type": "array",
      "description": "List of file paths the sub-agent is allowed to read for context. Replaces 'see above / refer to conversation'.",
      "items": { "type": "string" }
    },
    "owned_paths": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sc_id", "description"],
        "properties": {
          "sc_id": { "type": "string", "pattern": "^SC-[0-9]+$" },
          "description": { "type": "string", "minLength": 10 }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "must_exist"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string", "enum": ["file", "directory", "report"] },
          "must_exist": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    },
    "verify": {
      "type": "array",
      "description": "Anti-fill rule A: each entry must bind a command/path/assertion/test; not 'visual confirmation' alone.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sc_ref", "method", "cmd"],
        "properties": {
          "sc_ref": { "type": "string", "pattern": "^SC-[0-9]+$" },
          "method": { "type": "string", "enum": ["command", "path", "assertion", "test"] },
          "cmd": { "type": "string", "minLength": 3 },
          "expect": { "type": "string" }
        }
      }
    },
    "handoff_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_path_field", "status_field", "summary_field"],
      "properties": {
        "result_path_field": { "type": "string" },
        "status_field": { "type": "string" },
        "summary_field": { "type": "string" },
        "blockers_field": { "type": "string" }
      }
    }
  }
}
