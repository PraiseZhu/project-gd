{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praise.local/gd-v7/gd-child-plan-proposal.schema.json",
  "title": "GD Child Planner Proposal (Plan 6.5-C candidate)",
  "description": "Machine-readable child planner proposal output. Embedded in <!-- gd-child-plan-proposal-json:start --> ... :end --> block in child planner reply. Validated by scripts/gd-validate-child-proposal.py. Only template_kind=gd-child-plan-output is allowed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "parent_dispatch_id",
    "parent_track_id",
    "agent_role",
    "output_status",
    "summary_cn",
    "task_packets",
    "sc_refs",
    "verify",
    "blocked_reason"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "minLength": 3
    },
    "parent_dispatch_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_track_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_role": {
      "type": "string",
      "enum": ["child_planner"]
    },
    "output_status": {
      "type": "string",
      "enum": ["completed", "blocked_missing_context", "blocked_other"]
    },
    "summary_cn": {
      "type": "string",
      "minLength": 1
    },
    "task_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "owned_paths", "required_context"],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$",
            "minLength": 1
          },
          "owned_paths": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "required_context": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "sc_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SC-[0-9]+$"
      }
    },
    "verify": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sc_ref", "method", "cmd"],
        "properties": {
          "sc_ref": {"type": "string", "pattern": "^SC-[0-9]+$"},
          "method": {
            "type": "string",
            "enum": ["command", "path", "assertion", "test"]
          },
          "cmd": {"type": "string", "minLength": 3}
        }
      }
    },
    "blocked_reason": {
      "type": ["string", "null"],
      "description": "non-null when output_status != completed (≥10 chars); null when output_status == completed"
    }
  }
}
