{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praise.local/gd-v7/gd-plan-suite.schema.json",
  "title": "GD Plan Suite",
  "description": "Schema for /gd master plan + step plan goal/SC blocks. References gd-task-packet.schema.json for nested task packets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_kind",
    "gd_standard",
    "goal_source",
    "goal_chain",
    "review_alignment",
    "success_criteria",
    "non_goals",
    "boundaries"
  ],
  "properties": {
    "template_kind": {
      "type": "string",
      "enum": ["gd-master-plan", "gd-step-plan"]
    },
    "gd_standard": {
      "type": "string",
      "const": "Project GD/prompts/gd-review-standard.md"
    },
    "goal_source": {
      "type": "string",
      "const": "Project GD/docs/gd-v7-project-goal.md"
    },
    "goal_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["PROJECT_GOAL", "CHAIN_GOAL", "PHASE_GOAL"],
      "properties": {
        "PROJECT_GOAL": { "type": "string", "minLength": 10 },
        "CHAIN_GOAL": { "type": "string", "minLength": 10 },
        "PHASE_GOAL": { "type": "string", "minLength": 10 },
        "TASK_GOAL": { "type": "string", "minLength": 10 }
      }
    },
    "review_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["REVIEW_DOMAIN", "REVIEW_FOCUS"],
      "properties": {
        "REVIEW_DOMAIN": {
          "type": "string",
          "enum": ["ai_infra", "app_code", "docs_content", "other"]
        },
        "REVIEW_FOCUS": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 3,
          "maxItems": 5
        },
        "domain_specific_notes": { "type": "string" }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sc_id", "description", "verify"],
        "properties": {
          "sc_id": { "type": "string", "pattern": "^SC-[0-9]+$" },
          "description": { "type": "string", "minLength": 10 },
          "verify": {
            "description": "Anti-fill rule A: must contain command/path/assertion/test, not 'visual confirmation' alone",
            "type": "object",
            "additionalProperties": false,
            "required": ["method", "expression"],
            "properties": {
              "method": { "type": "string", "enum": ["command", "path", "assertion", "test"] },
              "expression": { "type": "string", "minLength": 3 },
              "expect": { "type": "string" }
            }
          }
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 5 },
      "minItems": 1
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modify", "do_not_modify"],
      "properties": {
        "modify": { "type": "array", "items": { "type": "string" } },
        "do_not_modify": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "task_packets": {
      "type": "array",
      "description": "List of task_packet file paths; each file conforms to gd-task-packet.schema.json",
      "items": { "type": "string" }
    }
  }
}
