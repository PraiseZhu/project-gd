{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praise.local/gd-v7/gd-dispatch-map.schema.json",
  "title": "GD Dispatch Map",
  "description": "Schema for /gd multi-agent dispatch maps. Structural reference; semantic checks are in scripts/gd-validate-dispatch.py (stdlib-only, does NOT depend on jsonschema lib).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dispatch_id",
    "source_master_plan",
    "goal_chain",
    "max_parallel_planning",
    "max_parallel_execution",
    "max_parallel_review",
    "max_parallel_validation",
    "tracks",
    "waves",
    "merge_gates"
  ],
  "properties": {
    "dispatch_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "source_master_plan": {
      "type": "string",
      "minLength": 1
    },
    "goal_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["PROJECT_GOAL", "CHAIN_GOAL", "PHASE_GOAL"],
      "properties": {
        "PROJECT_GOAL": { "type": "string", "minLength": 10 },
        "CHAIN_GOAL": { "type": "string", "minLength": 10 },
        "PHASE_GOAL": { "type": "string", "minLength": 10 }
      }
    },
    "max_parallel_planning": { "type": "integer", "minimum": 1, "maximum": 2 },
    "max_parallel_execution": { "type": "integer", "minimum": 1, "maximum": 2 },
    "max_parallel_review": { "type": "integer", "minimum": 1, "maximum": 2 },
    "max_parallel_validation": { "type": "integer", "minimum": 1, "maximum": 2 },
    "overrides_rationale": { "type": "string" },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "track_id", "mode", "agent_role",
          "owned_paths", "forbidden_paths",
          "required_context", "deliverables",
          "blocked_by", "can_parallel_with",
          "sc_refs", "verify"
        ],
        "properties": {
          "track_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "mode": { "type": "string", "enum": ["plan", "execute", "review", "validate"] },
          "agent_role": {
            "type": "string",
            "enum": ["child_planner", "child_executor", "child_reviewer", "child_validator"]
          },
          "owned_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "forbidden_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "required_context": { "type": "array", "items": { "type": "string" } },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "kind", "must_exist"],
              "properties": {
                "path": { "type": "string" },
                "kind": { "type": "string", "enum": ["file", "directory", "report"] },
                "must_exist": { "type": "boolean" }
              }
            }
          },
          "blocked_by": { "type": "array", "items": { "type": "string" } },
          "can_parallel_with": { "type": "array", "items": { "type": "string" } },
          "sc_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^SC-[0-9]+$" }
          },
          "verify": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sc_ref", "method", "cmd"],
              "properties": {
                "sc_ref": { "type": "string", "pattern": "^SC-[0-9]+$" },
                "method": { "type": "string", "enum": ["command", "path", "assertion", "test"] },
                "cmd": { "type": "string", "minLength": 3 },
                "expect": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wave_id", "track_ids"],
        "properties": {
          "wave_id": { "type": "string", "pattern": "^w[0-9]+$" },
          "track_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "description": { "type": "string" }
        }
      }
    },
    "merge_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "description"],
        "properties": {
          "gate_id": { "type": "string", "pattern": "^G[0-9]+$" },
          "description": { "type": "string", "minLength": 5 }
        }
      }
    }
  }
}
